# Oakestra Addons Dashboard - Environment Variables
#
# These variables are used at Docker container runtime to configure
# the application's API endpoints.
#
# Copy this file and customize the values as needed.

# Dashboard configuration
DASHBOARD_PORT=11103

# Marketplace API configuration
MARKETPLACE_PROTOCOL=http
MARKETPLACE_URL=localhost
MARKETPLACE_PORT=11102

# Addons Engine API configuration
ADDONS_ENGINE_PROTOCOL=http
ADDONS_ENGINE_URL=localhost
ADDONS_ENGINE_PORT=11101

# Resource Abstractor API configuration
RESOURCE_ABSTRACTOR_PROTOCOL=http
RESOURCE_ABSTRACTOR_URL=localhost
RESOURCE_ABSTRACTOR_PORT=10000
