{
    // Runs local 
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Node Engine",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceRoot}/go_node_engine/internal/daemon/nodeengined.go",
            "console": "integratedTerminal",
            "asRoot": true,
            "args": ["-a", "0.0.0.0",],
            "env": {
                "PATH": "${env:PATH}:/usr/local/go/bin" 
            },
            "preLaunchTask": "prep-debug-node-engine-env",        },
        {
            "name": "Debug Node Engine With Custom Cluster",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceRoot}/go_node_engine/internal/daemon/nodeengined.go",
            "console": "integratedTerminal",
            "asRoot": true,
            "args": ["-a","${input:enterClusterIp}"],
            "env": {
                "PATH": "${env:PATH}:/usr/local/go/bin" 
            }
        },
        {
            "name": "Debug Cluster Manager",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceRoot}/cluster_orchestrator/cluster-manager/cluster_manager.py",
            "console": "integratedTerminal",
            "env": {
                "PATH": "${env:PATH}:/usr/local/go/bin",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "True",
                "MQTT_BROKER_URL": "0.0.0.0",
                "MQTT_BROKER_PORT": "10003",
                "CLUSTER_MONGO_URL": "0.0.0.0",
                "CLUSTER_MONGO_PORT": "10107",
                "SYSTEM_MANAGER_PORT": "10000",
                "CLUSTER_SCHEDULER_URL": "0.0.0.0",
                "CLUSTER_SCHEDULER_PORT": "10105",
                "CLUSTER_SERVICE_MANAGER_ADDR": "0.0.0.0",
                "CLUSTER_SERVICE_MANAGER_PORT": "10110",
                "SYSTEM_MANAGER_URL": "0.0.0.0",
                "CLUSTER_LOCATION": "48.13023160559729,11.583724427641824,100",
                "CLUSTER_NAME": "debug_cluster",
                "RESOURCE_ABSTRACTOR_URL": "cluster_resource_abstractor",
                "RESOURCE_ABSTRACTOR_PORT": "11012",
                "MY_PORT": "10100",
                "SYSTEM_MANAGER_GRPC_PORT": "50052",
            },
            "preLaunchTask": "prep-debug-cluster-manager-env",
        },
        {
            "name": "Debug Cluster Scheduler",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceRoot}/cluster_orchestrator/cluster-scheduler/cluster_scheduler.py",
            "console": "integratedTerminal",
            "env": {
                "PATH": "${env:PATH}:/usr/local/go/bin",
                "FLASK_ENV": "development",
                "FLASK_DEBUG": "True",
                "MY_PORT":"10105",
                "CLUSTER_MANAGER_URL":"0.0.0.0",
                "CLUSTER_MANAGER_PORT":"10100",
                "CLUSTER_MONGO_URL":"0.0.0.0",
                "CLUSTER_MONGO_PORT":"10107",
                "REDIS_ADDR":"redis://:clusterRedis@0.0.0.0:6479"
            },
            "preLaunchTask": "prep-debug-cluster-scheduler-env",
        },
        {
            "name": "Cleanup Dev Environment",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceRoot}/cluster_orchestrator/cluster-manager/logs/cm_logging.py",
            "console": "integratedTerminal",
            "preLaunchTask": "cleanup-debug-env",
        }
    ],
    "inputs": [
        {
          "id": "enterClusterIp",
          "type": "promptString",
          "description": "Cluster Orchestrator IP",
          "default": "0.0.0.0"
        }
      ]
}