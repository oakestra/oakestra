ARG VERSION

FROM localhost/ubuntu-cloud:${VERSION}

RUN export DEBIAN_FRONTEND=noninteractive \
    && truncate --size 0 /etc/fstab \
    && apt-get update \
    && apt-get --yes purge cryptsetup \
    && apt-get --yes upgrade \
    && apt-get --yes install --no-install-recommends linux-virtual \
    && apt-get --yes autoremove \
    && apt-get --yes clean

COPY --chown=root:root --chmod=0600 netplan.yaml /etc/netplan/00-oakestra.yaml
